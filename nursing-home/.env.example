# ============================================
# 养老院智能监护系统 - 环境变量配置
# ============================================
# 复制此文件为 .env 并根据实际情况修改

# ---------- 服务器 ----------
PORT=3001
NODE_ENV=development

# ---------- 数据库 (PostgreSQL) ----------
# 方式一：单个连接字符串（优先级高）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nursing_home

# 方式二：分解配置（当 DATABASE_URL 未设置时生效）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nursing_home
DB_CONNECTION_LIMIT=10
# 云数据库需要 SSL (Render PostgreSQL 自动启用)
DB_SSL=true
